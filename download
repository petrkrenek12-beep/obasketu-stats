<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NBA Stats Generator</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0a0c;
            --bg-card: #14141a;
            --bg-card-2: #1c1c24;
            --accent: #ff5b1f;
            --accent-dim: #c44116;
            --text: #f0f0f0;
            --text-dim: #888;
            --border: #2a2a35;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Source Serif 4', Georgia, serif;
            min-height: 100vh;
            padding: 2rem 1rem;
            background-image: 
                radial-gradient(circle at 20% 0%, rgba(255, 91, 31, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 80% 100%, rgba(255, 91, 31, 0.05) 0%, transparent 50%);
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
        }

        header {
            margin-bottom: 3rem;
            border-bottom: 2px solid var(--border);
            padding-bottom: 1.5rem;
        }

        .logo {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 3rem;
            letter-spacing: 0.05em;
            color: var(--text);
            line-height: 1;
        }

        .logo .accent {
            color: var(--accent);
        }

        .tagline {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            margin-top: 0.5rem;
        }

        .search-box {
            display: flex;
            gap: 0.75rem;
            margin-bottom: 2rem;
        }

        input[type="text"] {
            flex: 1;
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 1rem 1.25rem;
            font-family: 'Source Serif 4', serif;
            font-size: 1.1rem;
            border-radius: 2px;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        input[type="text"]:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(255, 91, 31, 0.15);
        }

        button {
            background: var(--accent);
            color: var(--bg);
            border: none;
            padding: 0 2rem;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.2rem;
            letter-spacing: 0.1em;
            cursor: pointer;
            border-radius: 2px;
            transition: background 0.15s;
        }

        button:hover:not(:disabled) {
            background: var(--accent-dim);
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .examples {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--text-dim);
            margin-bottom: 2rem;
        }

        .examples span {
            cursor: pointer;
            margin-right: 0.5rem;
            padding: 0.25rem 0.5rem;
            border: 1px solid var(--border);
            border-radius: 2px;
            display: inline-block;
            margin-bottom: 0.3rem;
            transition: border-color 0.15s, color 0.15s;
        }

        .examples span:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .result {
            background: var(--bg-card);
            border-left: 4px solid var(--accent);
            padding: 2rem;
            margin-bottom: 1rem;
            animation: fadeIn 0.4s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .player-header {
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border);
        }

        .player-name {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.5rem;
            letter-spacing: 0.03em;
            line-height: 1;
        }

        .player-meta {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-top: 0.4rem;
        }

        .status-active {
            color: var(--accent);
        }

        .section-label {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1rem;
            letter-spacing: 0.2em;
            color: var(--accent);
            margin-top: 1.5rem;
            margin-bottom: 0.75rem;
            text-transform: uppercase;
        }

        .section-label:first-of-type {
            margin-top: 0;
        }

        .paragraph {
            font-size: 1.05rem;
            line-height: 1.7;
            color: var(--text);
        }

        .error {
            background: rgba(255, 91, 31, 0.1);
            border-left: 4px solid var(--accent);
            padding: 1rem 1.25rem;
            color: var(--text);
            font-style: italic;
        }

        .loading {
            text-align: center;
            padding: 2rem;
            color: var(--text-dim);
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .loading::after {
            content: '';
            display: inline-block;
            width: 1ch;
            text-align: left;
            animation: dots 1.4s infinite;
        }

        @keyframes dots {
            0%, 20% { content: ''; }
            40% { content: '.'; }
            60% { content: '..'; }
            80%, 100% { content: '...'; }
        }

        footer {
            text-align: center;
            color: var(--text-dim);
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.1em;
            margin-top: 3rem;
            text-transform: uppercase;
        }

        @media (max-width: 600px) {
            .logo { font-size: 2rem; }
            .player-name { font-size: 1.8rem; }
            .search-box { flex-direction: column; }
            button { padding: 0.8rem; }
            .result { padding: 1.25rem; }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <div class="logo">NBA <span class="accent">STATS</span></div>
            <div class="tagline">// Žurnalistický generátor profilů</div>
        </header>

        <div class="search-box">
            <input type="text" id="playerInput" placeholder="Jméno hráče (anglicky, např. Nikola Jokic)" autocomplete="off">
            <button id="searchBtn">Najít</button>
        </div>

        <div class="examples">
            Zkus:
            <span data-name="LeBron James">LeBron James</span>
            <span data-name="Nikola Jokic">Nikola Jokic</span>
            <span data-name="Luka Doncic">Luka Doncic</span>
            <span data-name="Stephen Curry">Stephen Curry</span>
            <span data-name="Victor Wembanyama">Victor Wembanyama</span>
        </div>

        <div id="output"></div>

        <footer>oBasketu · NBA Stats Tool</footer>
    </div>

    <script>
        const input = document.getElementById('playerInput');
        const btn = document.getElementById('searchBtn');
        const output = document.getElementById('output');

        async function searchPlayer() {
            const name = input.value.trim();
            if (!name) return;

            btn.disabled = true;
            output.innerHTML = '<div class="loading">Načítám data z NBA</div>';

            try {
                const res = await fetch(`/api/player?name=${encodeURIComponent(name)}`);
                const data = await res.json();

                if (!res.ok) {
                    output.innerHTML = `<div class="error">${data.error || 'Něco se pokazilo.'}</div>`;
                    return;
                }

                const teamLine = data.team ? data.team : 'Volný hráč / mimo soupisku';
                const status = data.is_active 
                    ? '<span class="status-active">● Aktivní</span>' 
                    : '○ Neaktivní';
                const pos = data.position || '–';

                output.innerHTML = `
                    <div class="result">
                        <div class="player-header">
                            <div class="player-name">${data.player}</div>
                            <div class="player-meta">${teamLine} · ${pos} · ${status}</div>
                        </div>
                        <div class="section-label">Aktuální sezóna</div>
                        <p class="paragraph">${data.season_paragraph}</p>
                        <div class="section-label">Kariéra</div>
                        <p class="paragraph">${data.career_paragraph}</p>
                    </div>
                `;
            } catch (e) {
                output.innerHTML = `<div class="error">Chyba sítě: ${e.message}</div>`;
            } finally {
                btn.disabled = false;
            }
        }

        btn.addEventListener('click', searchPlayer);
        input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') searchPlayer();
        });

        document.querySelectorAll('.examples span').forEach(el => {
            el.addEventListener('click', () => {
                input.value = el.dataset.name;
                searchPlayer();
            });
        });

        input.focus();
    </script>
</body>
</html>
